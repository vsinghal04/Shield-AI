{
  "name": "shieldai-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/download-datasets.js",
    "dev": "vite build --watch",
    "build": "vite build",
    "build:clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue; vite build",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "package": "npm run build && node scripts/package-extension.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "axios": "^1.7.0",
    "fast-levenshtein": "^3.0.0",
    "fuse.js": "^7.0.0",
    "idb": "^8.0.0",
    "jsqr": "^1.4.0",
    "onnxruntime-web": "^1.18.0",
    "punycode": "^2.3.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tesseract.js": "^5.1.0",
    "tldts": "^6.1.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@playwright/test": "^1.45.0",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "unzipper": "^0.12.3",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
